<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.tencent.wxcloudrun.dao.HabitMapper">
    
    <resultMap id="BaseResultMap" type="com.tencent.wxcloudrun.model.Habit">
        <id column="id" property="id"/>
        <result column="userId" property="userId"/>
        <result column="name" property="name"/>
        <result column="icon" property="icon"/>
        <result column="color" property="color"/>
        <result column="reminder" property="reminder"/>
        <result column="frequency" property="frequency"/>
        <result column="streak" property="streak"/>
        <result column="maxStreak" property="maxStreak"/>
        <result column="totalCheckIns" property="totalCheckIns"/>
        <result column="isActive" property="isActive"/>
        <result column="createdAt" property="createdAt"/>
        <result column="updatedAt" property="updatedAt"/>
    </resultMap>
    
    <sql id="Base_Column_List">
        id, userId, name, icon, color, reminder, frequency, streak, maxStreak, totalCheckIns, isActive, createdAt, updatedAt
    </sql>
    
    <select id="findByUserId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM habits
        WHERE userId = #{userId}
        ORDER BY createdAt DESC
    </select>
    
    <select id="findById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM habits
        WHERE id = #{id}
    </select>
    
    <insert id="insert" parameterType="com.tencent.wxcloudrun.model.Habit" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO habits (userId, name, icon, color, reminder, frequency, streak, maxStreak, totalCheckIns, isActive)
        VALUES (#{userId}, #{name}, #{icon}, #{color}, #{reminder}, #{frequency}, #{streak}, #{maxStreak}, #{totalCheckIns}, #{isActive})
    </insert>
    
    <update id="update" parameterType="com.tencent.wxcloudrun.model.Habit">
        UPDATE habits
        SET name = #{name},
            icon = #{icon},
            color = #{color},
            reminder = #{reminder},
            frequency = #{frequency},
            streak = #{streak},
            maxStreak = #{maxStreak},
            totalCheckIns = #{totalCheckIns},
            isActive = #{isActive}
        WHERE id = #{id}
    </update>
    
    <delete id="deleteById">
        DELETE FROM habits
        WHERE id = #{id}
    </delete>
    
    <delete id="deleteByUserId">
        DELETE FROM habits
        WHERE userId = #{userId}
    </delete>
    
</mapper>
